# 服务
PORT=3000
NODE_ENV=development

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=notebook

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# 加密
ENCRYPTION_KEY=
API_SECRET=change-me
BCRYPT_ROUNDS=10
FOLDER_UNLOCK_MINUTES=5

# 文件保险库（VAULT_ADMIN_RECOVERY_KEY 建议 32+ 字符随机串，与 ENCRYPTION_KEY 可相同但建议独立）
VAULT_ADMIN_RECOVERY_KEY=
VAULT_MAX_FILE_BYTES=1073741824
VAULT_DEFAULT_QUOTA_BYTES=21474836480
VAULT_CHUNK_BYTES=4194304
VAULT_UNLOCK_SESSION_MINUTES=15
VAULT_RECOVERY_TOKEN_HOURS=24
VAULT_RECOVERY_COOLDOWN_DAYS=30
VAULT_UPLOAD_SESSION_HOURS=24

# 上传限制（单位 MB）
UPLOAD_MAX_ATTACHMENT_MB=10
UPLOAD_MAX_AVATAR_MB=2

# 阿里云 OSS（可选；真实密钥请写在 .env，勿提交到 Git）
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=your-bucket-name
# OSS_ENDPOINT=
# OSS_PREFIX=
# OSS_CUSTOM_DOMAIN=
# OSS_SECURE=true
